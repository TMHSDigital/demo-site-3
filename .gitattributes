# Normalize line endings: store as LF in the repo, check out native on Windows.
* text=auto

# Web source files are always LF.
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf

# Treat binary assets as binary (no EOL conversion, no diff noise).
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.svg   text eol=lf
*.ico   binary
*.woff  binary
*.woff2 binary
